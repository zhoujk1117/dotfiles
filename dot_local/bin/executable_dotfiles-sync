#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  dotfiles-sync
  dotfiles-sync --commit [message]
  dotfiles-sync --push [message]
  dotfiles-sync --auto

The default action re-adds managed files, scans for high-confidence secrets,
and shows repository status. The guarded --auto mode is reserved for the
managed systemd timer.
EOF
}

action="status"
message=""
case ${1:-} in
  "") ;;
  --commit)
    action="commit"
    message=${2:-}
    ;;
  --push)
    action="push"
    message=${2:-}
    ;;
  --auto)
    action="auto"
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

log() {
  printf '[%s] %s\n' "$(date --iso-8601=seconds)" "$*"
}

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles-sync"
mkdir -p "$state_dir"
exec 9>"$state_dir/lock"
if ! flock -n 9; then
  log "another dotfiles sync is already running; skipping"
  exit 0
fi

source_dir=$(chezmoi source-path)
git_cmd=(git -C "$source_dir")
"${git_cmd[@]}" rev-parse --is-inside-work-tree >/dev/null

branch=$("${git_cmd[@]}" symbolic-ref --quiet --short HEAD) || {
  log "refusing to sync from a detached HEAD"
  exit 1
}
remote=origin

refresh_remote() {
  "${git_cmd[@]}" remote get-url "$remote" >/dev/null 2>&1 || {
    log "remote '$remote' is not configured"
    return 1
  }
  GIT_TERMINAL_PROMPT=0 "${git_cmd[@]}" fetch --quiet "$remote" "$branch"
}

check_remote_lineage() {
  local remote_ref="refs/remotes/$remote/$branch"
  "${git_cmd[@]}" show-ref --verify --quiet "$remote_ref" || return 0
  [[ $("${git_cmd[@]}" rev-parse HEAD) == $("${git_cmd[@]}" rev-parse "$remote_ref") ]] && return 0

  if "${git_cmd[@]}" merge-base --is-ancestor "$remote_ref" HEAD; then
    return 0
  fi

  if "${git_cmd[@]}" merge-base --is-ancestor HEAD "$remote_ref"; then
    log "remote branch is ahead; update manually before automatic sync"
  else
    log "local and remote branches have diverged; resolve manually"
  fi
  return 1
}

if [[ $action == "auto" || $action == "push" ]]; then
  log "checking $remote/$branch before sync"
  refresh_remote
  check_remote_lineage
fi

chezmoi re-add

secret_pattern='-----BEGIN [A-Z ]*PRIVATE KEY-----|github_pat_[A-Za-z0-9_]{20,}|gh[pousr]_[A-Za-z0-9]{30,}|AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9_-]{24,}'
if matches=$(rg -l --hidden -i -e "$secret_pattern" "$source_dir" -g '!.git/**' 2>/dev/null) && [[ -n $matches ]]; then
  echo "Possible secret material detected; refusing to continue:" >&2
  printf '%s\n' "$matches" >&2
  exit 1
fi

"${git_cmd[@]}" status --short
[[ $action == "status" ]] && exit 0

dotfiles-doctor
"${git_cmd[@]}" add -A
"${git_cmd[@]}" diff --cached --check

if ! "${git_cmd[@]}" diff --cached --quiet; then
  if [[ -z $("${git_cmd[@]}" config user.name) || -z $("${git_cmd[@]}" config user.email) ]]; then
    echo "Configure Git identity before committing:" >&2
    echo "  git -C \"$source_dir\" config user.name 'Your Name'" >&2
    echo "  git -C \"$source_dir\" config user.email 'you@example.com'" >&2
    exit 1
  fi
  if [[ -z $message ]]; then
    if [[ $action == "auto" ]]; then
      message="chore: auto-sync $(date --iso-8601=seconds)"
    else
      message="chore: sync $(date --iso-8601=seconds)"
    fi
  fi
  "${git_cmd[@]}" commit -m "$message"
fi

if [[ $action == "push" || $action == "auto" ]]; then
  refresh_remote
  check_remote_lineage
  if "${git_cmd[@]}" show-ref --verify --quiet "refs/remotes/$remote/$branch" && \
      [[ $("${git_cmd[@]}" rev-parse HEAD) == $("${git_cmd[@]}" rev-parse "refs/remotes/$remote/$branch") ]]; then
    log "nothing to push"
    exit 0
  fi
  GIT_TERMINAL_PROMPT=0 "${git_cmd[@]}" push "$remote" "HEAD:refs/heads/$branch"
  log "sync completed for $remote/$branch"
fi
