#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  dotfiles-sync
  dotfiles-sync --commit [message]
  dotfiles-sync --push [message]

The default action re-adds managed files, scans for high-confidence secrets,
and shows repository status. Commit and push are always explicit.
EOF
}

action="status"
message=""
case ${1:-} in
  "") ;;
  --commit)
    action="commit"
    message=${2:-}
    ;;
  --push)
    action="push"
    message=${2:-}
    ;;
  -h|--help)
    usage
    exit 0
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

source_dir=$(chezmoi source-path)
git -C "$source_dir" rev-parse --is-inside-work-tree >/dev/null
chezmoi re-add

secret_pattern='-----BEGIN [A-Z ]*PRIVATE KEY-----|github_pat_[A-Za-z0-9_]{20,}|gh[pousr]_[A-Za-z0-9]{30,}|AKIA[0-9A-Z]{16}|sk-[A-Za-z0-9_-]{24,}'
if matches=$(rg -l --hidden -i "$secret_pattern" "$source_dir" -g '!/.git/**' 2>/dev/null) && [[ -n $matches ]]; then
  echo "Possible secret material detected; refusing to continue:" >&2
  printf '%s\n' "$matches" >&2
  exit 1
fi

git -C "$source_dir" status --short
[[ $action == "status" ]] && exit 0

git -C "$source_dir" add -A
git -C "$source_dir" diff --cached --check

if ! git -C "$source_dir" diff --cached --quiet; then
  if [[ -z $(git -C "$source_dir" config user.name) || -z $(git -C "$source_dir" config user.email) ]]; then
    echo "Configure Git identity before committing:" >&2
    echo "  git -C \"$source_dir\" config user.name 'Your Name'" >&2
    echo "  git -C \"$source_dir\" config user.email 'you@example.com'" >&2
    exit 1
  fi
  [[ -n $message ]] || message="chore: sync $(date --iso-8601=seconds)"
  git -C "$source_dir" commit -m "$message"
fi

if [[ $action == "push" ]]; then
  if ! git -C "$source_dir" remote get-url origin >/dev/null 2>&1; then
    echo "No origin remote is configured" >&2
    exit 1
  fi
  git -C "$source_dir" push -u origin HEAD
fi
