#!/usr/bin/env bash
set -euo pipefail

packages=(
  alacritty
  bat
  btop
  chezmoi
  eza
  fastfetch
  fcitx5
  fcitx5-configtool
  fcitx5-gtk
  fcitx5-qt
  fcitx5-rime
  fd
  fish
  fzf
  git
  jq
  micro
  nautilus
  niri
  noctalia
  noctalia-shell
  ripgrep
  starship
  ttf-meslo-nerd
  wl-clipboard
  xdg-desktop-portal-gnome
  zsh
)

if ! command -v pacman >/dev/null 2>&1; then
  echo "This package helper currently supports Arch-based systems only" >&2
  exit 1
fi

missing=()
for package in "${packages[@]}"; do
  if [[ $package == "starship" ]] && command -v starship >/dev/null 2>&1; then
    continue
  fi
  if ! pacman -Q "$package" >/dev/null 2>&1; then
    missing+=("$package")
  fi
done

if ((${#missing[@]} == 0)); then
  echo "All desktop packages are installed"
  exit 0
fi

printf 'Missing packages:\n  %s\n' "${missing[*]}"

if [[ ${1:-} != "--install" ]]; then
  echo "Run dotfiles-packages --install to install them with pacman"
  exit 0
fi

unavailable=()
for package in "${missing[@]}"; do
  if ! pacman -Si "$package" >/dev/null 2>&1; then
    unavailable+=("$package")
  fi
done

if ((${#unavailable[@]} > 0)); then
  printf 'Unavailable in configured repositories:\n  %s\n' "${unavailable[*]}" >&2
  echo "Enable the appropriate CachyOS repositories before retrying" >&2
  exit 1
fi

sudo pacman -S --needed --noconfirm "${missing[@]}"
